{
  "name": "mkp-support",
  "productName": "MKP Support",
  "version": "0.2.1",
  "description": "MKP Support Electron Application",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "build": "electron-builder --win"
  },
  "keywords": [],
  "author": "Your Name",
  "license": "ISC",
  "dependencies": {
    "electron-updater": "^6.1.8"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.mkp.support.app",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "cloud_data",
        "to": "cloud_data",
        "filter": ["**/*"]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "MuCoreBenC",
        "repo": "MKP_Support_Electron"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MKP Support",
      "license": "license.txt"
    }
  }
}
